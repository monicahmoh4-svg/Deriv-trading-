# --- Server ---
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.com

# --- Database (PostgreSQL, e.g. Railway-provisioned) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# --- Token encryption (AES-256-GCM) ---
# Must be a 64-character hex string (32 bytes). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_char_hex_string

# --- Deriv API ---
# Register your own app at https://api.deriv.com/dashboard to get a production app_id.
# 1089 is Deriv's public demo app_id, fine for local testing only - do not use it in production.
DERIV_APP_ID=1089

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
